---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "Jim's Blog | Personal Digital Garden",
  description = "A personal website, technical blog, and digital learning lab designed with geek aesthetics and inspired by a quiet traveler's path.",
  image = "/placeholder-og.png",
  canonicalURL = Astro.url.href,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <!-- Theme Inline Script (to avoid FOUC / flashes) -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('color-theme')) {
          return localStorage.getItem('color-theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      
      const isDark = getThemePreference() === 'dark';
      document.documentElement.classList.toggle('light', !isDark);
    </script>

    <!-- Client Router -->
    <ClientRouter />

    <!-- Cloudflare Web Analytics (Replace token to enable) -->
    <!-- <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_CLOUDFLARE_ANALYTICS_TOKEN"}'></script> -->
  </head>
  <body class="bg-bg-main text-text-primary antialiased selection:bg-primary/30 selection:text-primary transition-colors duration-300">
    <!-- Grid HUD border layout decorations (subtle geek overlay) -->
    <div class="fixed inset-0 pointer-events-none border border-border-custom/20 m-4 z-40 rounded-lg"></div>
    <!-- Subtle top ambient glow -->
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-full max-w-7xl h-[300px] bg-primary/5 blur-[120px] pointer-events-none z-0"></div>

    <div class="flex min-h-screen">
      <!-- Left Sidebar (fixed on desktop, slide-out drawer on mobile) -->
      <Sidebar />

      <!-- Mobile drawer backdrop overlay -->
      <div id="sidebar-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 lg:hidden hidden"></div>

      <!-- Mobile top bar header -->
      <header class="lg:hidden fixed top-0 left-0 right-0 z-40 h-14 bg-bg-sidebar border-b border-border-custom px-4 flex items-center justify-between">
        <a href="/" class="flex items-center space-x-2 text-primary font-bold font-mono">
          <span>&lt;/&gt;</span>
          <span class="text-text-primary text-sm tracking-wider">JIM'S BLOG</span>
        </a>
        <button id="mobile-sidebar-toggle" class="p-2 text-text-secondary hover:text-primary rounded-lg border border-border-custom bg-bg-main/50 cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </header>

      <!-- Right main scrollable area -->
      <div class="flex-grow flex flex-col min-h-screen ml-0 lg:ml-64 pt-14 lg:pt-0">
        <main class="relative z-10 flex-grow mx-auto w-full max-w-5xl px-4 py-8 md:px-8">
          <slot />
        </main>
      </div>
    </div>

    <script>
      function setupMobileSidebar() {
        const toggleBtn = document.getElementById('mobile-sidebar-toggle');
        const sidebar = document.getElementById('sidebar-container');
        const backdrop = document.getElementById('sidebar-backdrop');
        
        if (!toggleBtn || !sidebar || !backdrop) return;
        
        function toggle() {
          sidebar?.classList.toggle('-translate-x-full');
          backdrop?.classList.toggle('hidden');
        }
        
        toggleBtn.addEventListener('click', toggle);
        backdrop.addEventListener('click', toggle);
      }
      
      setupMobileSidebar();
      document.addEventListener('astro:after-swap', setupMobileSidebar);
    </script>
  </body>
</html>
