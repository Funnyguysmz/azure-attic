---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import Card from '../../components/Card.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(post => post.data.tags))];
  
  return tags.map(tag => {
    const filteredPosts = posts.filter(post => post.data.tags.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={`Tag: #${tag} | Jim's Blog`}>
  <PageHeader />

  <section class="py-12 space-y-12">
    <!-- Header -->
    <div class="space-y-4 border-b border-border-custom/50 pb-8">
      <h1 class="text-3xl font-extrabold tracking-tight text-text-primary">
        Tag: <span class="text-primary font-mono">#{tag}</span>
      </h1>
      <p class="text-sm text-text-secondary leading-relaxed">
        正在展示标有该标签的所有文章。 <a href="/blog" class="text-primary hover:underline ml-2">返回全部文章 &rarr;</a>
      </p>
    </div>

    <!-- Posts list -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedPosts.length > 0 ? (
        sortedPosts.map(post => (
          <Card 
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id}`}
            date={new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            tags={post.data.tags}
          />
        ))
      ) : (
        <p class="text-sm text-text-secondary">未找到该标签的文章。</p>
      )}
    </div>
  </section>
</BaseLayout>
