---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import Callout from '../../components/mdx/Callout.astro';
import Tabs from '../../components/mdx/Tabs.astro';
import TabItem from '../../components/mdx/TabItem.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Filter out English posts so we only route Chinese/default posts under /blog/[slug]
  const zhPosts = posts.filter(post => !post.id.startsWith('en/'));
  return zhPosts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<PostLayout 
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  headings={headings}
  body={post.body || ''}
>
  <Content components={{ Callout, Tabs, TabItem }} />
</PostLayout>
