---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../layouts/PostLayout.astro';
import Callout from '../../../components/mdx/Callout.astro';
import Tabs from '../../../components/mdx/Tabs.astro';
import TabItem from '../../../components/mdx/TabItem.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Filter for posts that are stored inside the en/ folder, and map the slug parameters without the en/ prefix
  const enPosts = posts.filter(post => post.id.startsWith('en/'));
  return enPosts.map(post => ({
    params: { slug: post.id.replace(/^en\//, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<PostLayout 
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  headings={headings}
  body={post.body || ''}
>
  <Content components={{ Callout, Tabs, TabItem }} />
</PostLayout>
