---
---

<div class="w-full max-w-xl mx-auto rounded-lg border border-border-custom bg-bg-surface overflow-hidden shadow-2xl font-mono text-sm leading-relaxed transition-all duration-300">
  <!-- Terminal Title Bar -->
  <div class="flex items-center justify-between px-4 py-2 border-b border-border-custom bg-bg-main/50 select-none">
    <div class="flex items-center space-x-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ef4444] opacity-80"></span>
      <span class="w-3 h-3 rounded-full bg-[#eab308] opacity-80"></span>
      <span class="w-3 h-3 rounded-full bg-[#22c55e] opacity-80"></span>
    </div>
    <span class="text-xs text-text-secondary">roxy@traveler-laptop:~</span>
    <span class="w-10"></span> <!-- spacer -->
  </div>
  
  <!-- Terminal Body -->
  <div class="p-4 md:p-6 space-y-4 text-left min-h-[220px]">
    <div>
      <span class="text-primary font-bold">roxy@traveler-laptop</span>:<span class="text-secondary">~</span>$ <span id="cmd-1" class="text-text-primary"></span><span id="cursor-1" class="text-text-primary animate-pulse">■</span>
      <p id="output-1" class="text-text-secondary mt-1 ml-4 hidden">
        A static-site developer & explorer. Pursuing frontend craftsmanship and Serverless systems.
      </p>
    </div>
    
    <div id="block-2" class="hidden">
      <span class="text-primary font-bold">roxy@traveler-laptop</span>:<span class="text-secondary">~</span>$ <span id="cmd-2" class="text-text-primary"></span><span id="cursor-2" class="text-text-primary animate-pulse">■</span>
      <div id="output-2" class="text-text-secondary mt-1 ml-4 text-xs md:text-sm hidden">
        <span class="text-[#38bdf8]">&#123;</span><br/>
        &nbsp;&nbsp;<span class="text-primary">"languages"</span>: <span class="text-secondary">["TypeScript", "JavaScript", "Markdown"]</span>,<br/>
        &nbsp;&nbsp;<span class="text-primary">"frameworks"</span>: <span class="text-secondary">["Astro", "TailwindCSS", "Node.js"]</span>,<br/>
        &nbsp;&nbsp;<span class="text-primary">"interests"</span>: <span class="text-secondary">["Web Dev", "Serverless", "Anime Log"]</span><br/>
        <span class="text-[#38bdf8]">&#125;</span>
      </div>
    </div>

    <div id="block-3" class="hidden">
      <span class="text-primary font-bold">roxy@traveler-laptop</span>:<span class="text-secondary">~</span>$ <span class="text-text-primary animate-pulse">■</span>
    </div>
  </div>
</div>

<style>
  /* Subtle terminal flicker or glow */
  .shadow-2xl {
    box-shadow: 0 25px 50px -12px rgba(11, 15, 23, 0.5);
  }
</style>

<script>
  function runTerminalAnimation() {
    const cmd1 = document.getElementById('cmd-1');
    const cursor1 = document.getElementById('cursor-1');
    const output1 = document.getElementById('output-1');
    
    const block2 = document.getElementById('block-2');
    const cmd2 = document.getElementById('cmd-2');
    const cursor2 = document.getElementById('cursor-2');
    const output2 = document.getElementById('output-2');
    
    const block3 = document.getElementById('block-3');
    
    if (!cmd1 || !output1 || !block2 || !cmd2 || !output2 || !block3) return;

    // Reset states
    cmd1.textContent = '';
    cursor1.classList.remove('hidden');
    output1.classList.add('hidden');
    
    block2.classList.add('hidden');
    cmd2.textContent = '';
    cursor2.classList.remove('hidden');
    output2.classList.add('hidden');
    
    block3.classList.add('hidden');

    const text1 = 'whoami';
    const text2 = 'cat skills.json';
    
    let i = 0;
    function typeCmd1() {
      if (i < text1.length) {
        cmd1.textContent += text1.charAt(i);
        i++;
        setTimeout(typeCmd1, 100);
      } else {
        cursor1.classList.add('hidden');
        output1.classList.remove('hidden');
        setTimeout(() => {
          block2.classList.remove('hidden');
          typeCmd2();
        }, 500);
      }
    }

    let j = 0;
    function typeCmd2() {
      if (j < text2.length) {
        cmd2.textContent += text2.charAt(j);
        j++;
        setTimeout(typeCmd2, 100);
      } else {
        cursor2.classList.add('hidden');
        output2.classList.remove('hidden');
        setTimeout(() => {
          block3.classList.remove('hidden');
        }, 500);
      }
    }

    // Start typing
    setTimeout(typeCmd1, 500);
  }

  // Run on mount
  runTerminalAnimation();

  // Run again after view transition navigations
  document.addEventListener('astro:after-swap', runTerminalAnimation);
</script>
