---
import { getLocale, useTranslations } from '../utils/i18n';

const pathname = Astro.url.pathname;
const lang = getLocale(pathname);
const t = useTranslations(pathname);

// Map paths based on language prefix
const getPath = (path: string) => {
  if (lang === 'en') {
    return `/en${path === '/' ? '' : path}`;
  }
  return path;
};

const navItems = [
  { href: getPath('/'), label: t('nav.home'), icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6' },
  { href: getPath('/blog'), label: t('nav.articles'), icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
  { href: '/study', label: t('nav.study'), icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5s3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18s-3.332.477-4.5 1.253' },
  { href: getPath('/projects'), label: t('nav.projects'), icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4' },
  { href: getPath('/blog'), label: t('nav.tags'), icon: 'M7 7h.01M6 20h.01M12 20h.01M18 20h.01M6 14h.01M12 14h.01M18 14h.01M6 8h.01M12 8h.01M18 8h.01' }, // we can link to /blog for tag filtering
  { href: getPath('/about'), label: t('nav.about'), icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  { href: getPath('/timeline'), label: t('nav.archive'), icon: 'M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4' },
  { href: getPath('/blog'), label: t('nav.guestbook'), icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z' },
];

const currentYear = new Date().getFullYear();
---

<!-- Sidebar container -->
<aside id="sidebar-container" class="fixed top-0 bottom-0 left-0 z-50 w-64 border-r border-border-custom bg-bg-sidebar -translate-x-full lg:translate-x-0 flex flex-col justify-between px-6 py-8 transition-all duration-300 select-none">
  <!-- Brand Header -->
  <div class="space-y-2">
    <a href={getPath('/')} class="flex items-center space-x-3 text-2xl font-black font-mono tracking-tight text-primary">
      <span>&lt;/&gt;</span>
      <span class="text-text-primary text-lg tracking-wider">{t('brand.title')}</span>
    </a>
  </div>

  <!-- Navigation menu -->
  <nav class="flex-grow my-12 flex flex-col justify-start space-y-2">
    {navItems.map(item => {
      const isActive = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
      return (
        <a 
          href={item.href} 
          class={`flex items-center space-x-4 px-4 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 ${
            isActive 
              ? 'text-primary bg-primary/10 border border-primary/20 shadow shadow-primary/5' 
              : 'text-text-secondary hover:text-text-primary hover:bg-bg-surface/50 border border-transparent'
          }`}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
          </svg>
          <span class="font-mono text-xs tracking-wide">{item.label}</span>
        </a>
      );
    })}
  </nav>

  <!-- Sidebar Footer -->
  <div class="space-y-6 border-t border-border-custom/50 pt-6">
    <!-- Social Icons -->
    <div class="flex items-center space-x-6 justify-start px-2">
      <!-- GitHub -->
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="text-text-secondary hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.483 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.479C19.138 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" /></svg>
      </a>
      <!-- Mail -->
      <a href="mailto:example@example.com" class="text-text-secondary hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
      </a>
      <!-- RSS -->
      <a href="/rss.xml" class="text-text-secondary hover:text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" /></svg>
      </a>
    </div>

    <!-- Small Traveler Avatar Silhouette -->
    <div class="flex items-center space-x-3 bg-bg-main/60 p-3 rounded-lg border border-border-custom">
      <div class="w-8 h-8 rounded-full border border-primary/20 bg-primary/10 flex items-center justify-center text-sm overflow-hidden select-none">
        🔮
      </div>
      <div>
        <p class="text-[10px] font-mono font-bold text-text-primary">Roxy Migurdia</p>
        <p class="text-[8px] font-mono text-text-secondary">lvl. 99 Mage</p>
      </div>
    </div>

    <!-- Footer Copyright -->
    <div class="text-[10px] text-text-secondary font-mono leading-relaxed px-2 space-y-1">
      <p>&copy; {currentYear} Jim's Blog</p>
      <p class="opacity-60">{t('footer.built')} &bull; Cloudflare</p>
    </div>
  </div>
</aside>
