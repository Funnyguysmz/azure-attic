---
interface Props {
  type?: 'info' | 'warning' | 'danger' | 'success';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const styles = {
  info: {
    border: 'border-blue-500/35 bg-blue-500/5',
    text: 'text-blue-400',
    icon: 'ℹ️',
  },
  warning: {
    border: 'border-yellow-500/35 bg-yellow-500/5',
    text: 'text-yellow-400',
    icon: '⚠️',
  },
  danger: {
    border: 'border-red-500/35 bg-red-500/5',
    text: 'text-red-400',
    icon: '🚨',
  },
  success: {
    border: 'border-green-500/35 bg-green-500/5',
    text: 'text-green-400',
    icon: '✅',
  },
};

const currentStyle = styles[type] || styles.info;
---

<div class={`my-6 p-4 rounded-lg border ${currentStyle.border} flex items-start space-x-3 text-xs md:text-sm text-text-secondary leading-relaxed`}>
  <span class="text-base select-none leading-none pt-0.5">{currentStyle.icon}</span>
  <div class="space-y-1">
    {title && <h4 class={`font-bold ${currentStyle.text} font-mono`}>{title}</h4>}
    <div>
      <slot />
    </div>
  </div>
</div>
