<tabs-container class="block my-6 rounded-lg border border-border-custom bg-bg-surface overflow-hidden shadow-sm">
  <!-- Tabs list header -->
  <div class="tabs-headers flex items-center border-b border-border-custom bg-bg-main/50 px-2 py-1.5 space-x-1 overflow-x-auto select-none">
    <!-- Buttons dynamically generated by Web Component JS -->
  </div>
  
  <!-- Content panes -->
  <div class="tabs-panes p-4 text-xs md:text-sm text-text-secondary leading-relaxed">
    <slot />
  </div>
</tabs-container>

<script>
  class TabsContainer extends HTMLElement {
    connectedCallback() {
      const headersContainer = this.querySelector('.tabs-headers');
      const panes = this.querySelectorAll('.tab-pane');
      if (!headersContainer || panes.length === 0) return;

      // Clear headers to avoid duplication on re-renders/back-navs
      headersContainer.innerHTML = '';

      panes.forEach((pane, idx) => {
        const label = pane.getAttribute('data-label') || `Tab ${idx + 1}`;
        const btn = document.createElement('button');
        
        // Tailwind styling matching Roxy color palettes
        btn.className = 'px-3 py-1.5 text-xs font-mono font-medium rounded-md text-text-secondary hover:text-text-primary hover:bg-bg-main/30 transition-all cursor-pointer border border-transparent';
        btn.textContent = label;
        btn.classList.add('tab-btn');
        
        btn.addEventListener('click', () => {
          // Deactivate all buttons
          this.querySelectorAll('.tab-btn').forEach(b => {
            b.classList.remove('text-primary', 'bg-bg-main', 'border-border-custom');
            b.classList.add('text-text-secondary', 'border-transparent');
          });
          
          // Hide all panes
          panes.forEach(p => p.classList.add('hidden'));

          // Activate selected button
          btn.classList.add('text-primary', 'bg-bg-main', 'border-border-custom');
          btn.classList.remove('text-text-secondary', 'border-transparent');
          
          // Show selected pane
          pane.classList.remove('hidden');
        });

        headersContainer.appendChild(btn);

        // Auto-activate first tab
        if (idx === 0) {
          btn.classList.add('text-primary', 'bg-bg-main', 'border-border-custom');
          btn.classList.remove('text-text-secondary', 'border-transparent');
          pane.classList.remove('hidden');
        }
      });
    }
  }

  // Define the custom element if it doesn't already exist
  if (!customElements.get('tabs-container')) {
    customElements.define('tabs-container', TabsContainer);
  }
</script>
