---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../PageHeader.astro';

interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
---

<BaseLayout title={lang === 'zh' ? "交互实验室 | Jim's Blog" : "Lab Playground | Jim's Blog"}>
  <PageHeader />

  <section class="py-12 space-y-12">
    <!-- Header -->
    <div class="space-y-4 border-b border-border-custom/50 pb-8">
      <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight text-text-primary">
        {lang === 'zh' ? '交互沙盒 & 实验室' : 'Lab Playground & Sandbox'}
      </h1>
      <p class="text-sm md:text-base text-text-secondary leading-relaxed max-w-3xl">
        {lang === 'zh' 
          ? 'HTML5 Canvas 动画、SVG 图形以及一些视觉微动效的沙盒。点击并移动您的鼠标。' 
          : 'A sandbox for interactive canvas, SVG mathematics, and visual experiments. Click and move your mouse.'}
      </p>
    </div>

    <!-- Spell component card -->
    <div class="space-y-6">
      <div class="flex items-center justify-between border border-border-custom bg-bg-surface/50 px-4 py-2 rounded-t-lg border-b-0 font-mono text-xs select-none">
        <span class="text-primary font-bold">
          {lang === 'zh' ? '🧪 魔法法术-01: 互动 Canvas 魔法阵' : '🧪 Spell-01: Interactive Canvas Magic Circle'}
        </span>
        <span class="text-text-secondary">Status: Online</span>
      </div>
      
      <div class="relative w-full aspect-square md:aspect-[16/9] border border-border-custom bg-bg-main overflow-hidden rounded-b-lg group">
        <canvas id="magic-canvas" class="absolute inset-0 w-full h-full cursor-crosshair"></canvas>
        
        <div class="absolute bottom-4 left-4 font-mono text-[10px] text-text-secondary bg-bg-surface/80 px-2 py-1 rounded border border-border-custom/50 pointer-events-none select-none">
          <span>SYSTEM COORD: </span><span id="canvas-coord">[0.00, 0.00]</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function initCanvasSpell() {
    const canvas = document.getElementById('magic-canvas') as HTMLCanvasElement | null;
    const coordDisplay = document.getElementById('canvas-coord');
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    function resize() {
      if (!canvas) return;
      const rect = canvas.getBoundingClientRect();
      canvas.width = rect.width * window.devicePixelRatio;
      canvas.height = rect.height * window.devicePixelRatio;
      ctx?.scale(window.devicePixelRatio, window.devicePixelRatio);
    }
    resize();
    window.addEventListener('resize', resize);

    let mouse = { x: 0, y: 0, active: false };
    
    canvas.addEventListener('mousemove', (e) => {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      mouse.active = true;
      if (coordDisplay) {
        coordDisplay.textContent = `[${mouse.x.toFixed(2)}, ${mouse.y.toFixed(2)}]`;
      }
    });

    canvas.addEventListener('mouseleave', () => {
      mouse.active = false;
      if (coordDisplay) {
        coordDisplay.textContent = `[offline, offline]`;
      }
    });

    interface Particle {
      x: number;
      y: number;
      vx: number;
      vy: number;
      alpha: number;
      life: number;
      size: number;
    }
    const particles: Particle[] = [];

    function addParticle(x: number, y: number) {
      const angle = Math.random() * Math.PI * 2;
      const speed = Math.random() * 1.5 + 0.5;
      particles.push({
        x,
        y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed,
        alpha: 1.0,
        life: Math.random() * 30 + 30,
        size: Math.random() * 2 + 1,
      });
    }

    let angle = 0;

    function animate() {
      if (!canvas || !ctx) return;
      
      const width = canvas.width / window.devicePixelRatio;
      const height = canvas.height / window.devicePixelRatio;
      const cx = width / 2;
      const cy = height / 2;

      ctx.clearRect(0, 0, width, height);

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(angle);
      
      ctx.beginPath();
      ctx.arc(0, 0, 70, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(91, 131, 194, 0.4)';
      ctx.lineWidth = 1;
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(0, 0, 90, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(56, 189, 248, 0.25)';
      ctx.lineWidth = 0.5;
      ctx.stroke();

      ctx.beginPath();
      for (let i = 0; i < 6; i++) {
        const theta = (i * Math.PI) / 3;
        const x = Math.cos(theta) * 70;
        const y = Math.sin(theta) * 70;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.strokeStyle = 'rgba(91, 131, 194, 0.25)';
      ctx.stroke();

      ctx.beginPath();
      for (let i = 0; i < 3; i++) {
        const theta = (i * Math.PI * 2) / 3;
        const x = Math.cos(theta) * 90;
        const y = Math.sin(theta) * 90;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.stroke();

      ctx.beginPath();
      for (let i = 0; i < 3; i++) {
        const theta = ((i * Math.PI * 2) / 3) + Math.PI;
        const x = Math.cos(theta) * 90;
        const y = Math.sin(theta) * 90;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.closePath();
      ctx.stroke();

      ctx.restore();

      if (mouse.active) {
        if (Math.random() < 0.3) {
          addParticle(mouse.x, mouse.y);
        }
      } else {
        if (Math.random() < 0.1) {
          const r = Math.random() * 80 + 10;
          const a = Math.random() * Math.PI * 2;
          addParticle(cx + Math.cos(a) * r, cy + Math.sin(a) * r);
        }
      }

      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.x += p.vx;
        p.y += p.vy;
        p.life--;
        p.alpha = Math.max(0, p.life / 60);

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(56, 189, 248, ${p.alpha * 0.8})`;
        ctx.fill();

        if (p.life <= 0) {
          particles.splice(i, 1);
        }
      }

      angle += 0.003;
      requestAnimationFrame(animate);
    }
    
    animate();
  }

  initCanvasSpell();
  document.addEventListener('astro:after-swap', initCanvasSpell);
</script>
