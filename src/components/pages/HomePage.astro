---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../PageHeader.astro';
import TerminalIntro from '../TerminalIntro.astro';
import { useTranslations } from '../../utils/i18n';

interface Props {
  lang: 'zh' | 'en';
}

const { lang } = Astro.props;
const t = useTranslations(lang === 'en' ? '/en' : '/');

// Fetch collections
const posts = await getCollection('blog');
const studyEntries = await getCollection('study');
const projects = await getCollection('projects');

// Filter posts
const filteredPosts = posts
  .filter((post) => lang === 'en' ? post.id.startsWith('en/') : !post.id.startsWith('en/'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Calculate stats
const articlesCount = posts.filter((post) => lang === 'en' ? post.id.startsWith('en/') : !post.id.startsWith('en/')).length;
const projectsCount = projects.length;
const tagsCount = [...new Set(posts.flatMap(p => p.data.tags))].length;

// Static placeholders for mockup illustrations
import roxyHeroImg from '../../assets/images/roxy-hero.png';
import studyDeskImg from '../../assets/images/mage-study-desk.png';
import designBlueprintImg from '../../assets/images/blog-design-blueprint.png';
---

<BaseLayout title={lang === 'zh' ? "首页 | Jim's Blog" : "Home | Jim's Blog"}>
  
  <!-- Reusable Page Header -->
  <PageHeader />

  <!-- Hero Section -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-12 items-center py-6 md:py-10 border-b border-border-custom/50 relative">
    <!-- Left Hero content -->
    <div class="lg:col-span-7 space-y-6 text-left relative z-10">
      <span class="block font-mono text-xs text-text-secondary select-none">&gt; whoami</span>
      
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-text-primary leading-tight">
        {t('hero.hello')}<br/>
        {lang === 'zh' ? '我是' : "I'm"} <span class="text-primary font-mono select-all">Jim.</span>
      </h1>
      
      <p class="text-sm md:text-base text-text-secondary leading-relaxed max-w-xl">
        {t('hero.slogan')}
      </p>

      <!-- Terminal interests component -->
      <div class="w-full">
        <TerminalIntro />
      </div>

      <!-- Quick Action Buttons -->
      <div class="flex flex-wrap items-center gap-4 pt-2">
        <a 
          href={lang === 'en' ? '/en/blog' : '/blog'} 
          class="inline-flex items-center space-x-2 text-xs font-mono font-bold text-primary hover:text-accent hover:translate-x-1 transition-all duration-300"
        >
          <span>{t('hero.explore')}</span>
          <span>&rarr;</span>
        </a>
        <a 
          href="/study" 
          class="inline-flex items-center space-x-2 text-xs font-mono font-bold text-text-secondary hover:text-primary hover:translate-x-1 transition-all duration-300"
        >
          <span>学习资料 Study</span>
          <span>&rarr;</span>
        </a>
      </div>
    </div>
    
    <!-- Right Hero Mage Illustration -->
    <div class="lg:col-span-5 relative w-full flex justify-center items-center">
      <!-- Fading glow backdrop -->
      <div class="absolute w-[280px] h-[280px] bg-primary/10 rounded-full blur-[80px] z-0 pointer-events-none"></div>
      
      <!-- Illustration frame -->
      <div class="relative w-[320px] aspect-[4/5] rounded-xl border border-border-custom bg-bg-surface overflow-hidden shadow-2xl z-10 transition-transform duration-500 hover:scale-[1.01]">
        <Image 
          src={roxyHeroImg}
          alt="Roxy mage hero illustration"
          class="w-full h-full object-cover opacity-90 transition-opacity duration-300 hover:opacity-100"
          loading="eager"
        />
        
        <!-- vertical quotes overlays matching mockup -->
        <div class="absolute right-4 top-1/2 -translate-y-1/2 font-mono text-[9px] text-text-secondary/60 tracking-[0.3em] select-none writing-vertical pointer-events-none uppercase">
          人生は冒険だ。楽しんだ者が勝ちだよ。
        </div>

        <!-- Scroll down indicators -->
        <div class="absolute bottom-4 left-4 font-mono text-[8px] text-text-secondary tracking-widest flex flex-col space-y-1 select-none">
          <span>01</span>
          <span class="opacity-50">SCROLL DOWN ⌵</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Articles Section -->
  <section class="py-12 border-b border-border-custom/50">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-sm font-bold text-text-primary tracking-wider font-mono flex items-center space-x-2">
        <span class="text-primary">/</span>
        <span>{t('home.latest')}</span>
      </h2>
      <a 
        href={lang === 'en' ? '/en/blog' : '/blog'} 
        class="text-[10px] font-mono font-bold text-text-secondary hover:text-primary transition-colors uppercase tracking-wider"
      >
        {t('home.viewall')} &rarr;
      </a>
    </div>

    <!-- Horizontal card layouts matching mockup -->
    <div class="grid grid-cols-1 gap-4">
      {filteredPosts.map((post, idx) => {
        const cover = idx % 2 === 0 ? studyDeskImg : designBlueprintImg;
        return (
          <a 
            href={lang === 'en' ? `/en/blog/${post.id}` : `/blog/${post.id}`}
            class="group flex flex-col md:flex-row gap-6 p-4 rounded-lg border border-border-custom bg-bg-surface hover:border-primary/40 transition-all duration-300 hover:shadow-lg hover:shadow-primary/5"
          >
            <!-- Left Thumbnail -->
            <div class="w-full md:w-36 h-24 rounded-md overflow-hidden bg-bg-main border border-border-custom/50 flex-shrink-0 relative">
              <Image 
                src={cover} 
                alt={post.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            </div>
            
            <!-- Right Details -->
            <div class="flex-grow flex flex-col justify-between py-1">
              <div class="space-y-2">
                <div class="flex items-center justify-between">
                  <span class="text-[9px] font-mono font-bold uppercase text-primary bg-primary/10 border border-primary/20 px-1.5 py-0.5 rounded">
                    {post.data.tags[0] || 'Article'}
                  </span>
                </div>
                <h3 class="text-sm md:text-base font-bold text-text-primary group-hover:text-primary transition-colors duration-300 font-sans">
                  {post.data.title}
                </h3>
                <p class="text-xs text-text-secondary line-clamp-1 leading-relaxed">
                  {post.data.description}
                </p>
              </div>
              
              <!-- Card Meta footer -->
              <div class="flex items-center space-x-4 text-[9px] font-mono text-text-secondary border-t border-border-custom/30 pt-2 mt-2">
                <time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit' })}</time>
                <span>&bull;</span>
                <span>{post.id.includes('hello-world') ? '5 min read' : '8 min read'}</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Quote & Statistics Row -->
  <section class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center py-12">
    <!-- Left Column: Quote -->
    <div class="lg:col-span-6 flex items-start space-x-4">
      <span class="text-3xl text-primary font-serif leading-none select-none">“</span>
      <div class="space-y-2">
        <p class="text-xs md:text-sm text-text-secondary leading-relaxed italic">
          {lang === 'zh' 
            ? '“魔法工坊里也好，长剑修炼里也好，只要付出真心，那便会化为我的全部。”' 
            : '"Whether it is magic or sword, if I do it with all my heart, it will become my everything."'}
        </p>
        <cite class="block text-[10px] font-mono text-primary not-italic">
          &mdash; {lang === 'zh' ? '洛琪希·米格路迪亚 (Roxy Migurdia)' : 'Roxy Migurdia'}
        </cite>
      </div>
    </div>

    <!-- Right Column: Stats Row -->
    <div class="lg:col-span-6 grid grid-cols-4 gap-4 text-center select-none">
      <div class="p-3 rounded-lg border border-border-custom bg-bg-surface/50">
        <span class="block text-lg md:text-xl font-black text-primary font-mono">{articlesCount}</span>
        <span class="text-[8px] text-text-secondary font-mono tracking-wider uppercase block mt-1">{t('stats.articles')}</span>
      </div>
      <div class="p-3 rounded-lg border border-border-custom bg-bg-surface/50">
        <span class="block text-lg md:text-xl font-black text-primary font-mono">{projectsCount}</span>
        <span class="text-[8px] text-text-secondary font-mono tracking-wider uppercase block mt-1">{t('stats.projects')}</span>
      </div>
      <div class="p-3 rounded-lg border border-border-custom bg-bg-surface/50">
        <span class="block text-lg md:text-xl font-black text-primary font-mono">{tagsCount}</span>
        <span class="text-[8px] text-text-secondary font-mono tracking-wider uppercase block mt-1">{t('stats.tags')}</span>
      </div>
      <div class="p-3 rounded-lg border border-border-custom bg-bg-surface/50">
        <span class="block text-lg md:text-xl font-black text-primary font-mono">{studyEntries.length}</span>
        <span class="text-[8px] text-text-secondary font-mono tracking-wider uppercase block mt-1">STUDY</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Vertical text rules */
  .writing-vertical {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }
</style>
